# Django
SECRET_KEY=change-me-for-local-development
DJANGO_SETTINGS_MODULE=stockq.settings.local
DEBUG_MODE=True
ALLOWED_HOSTS=localhost,127.0.0.1

# External APIs
OPENAI_API_KEY=dummy-openai-key
OPENAI_MODEL=gpt-4.1-mini
FINNHUB_API_KEY=dummy-finnhub-key

# PostgreSQL for Docker/local prod-like runs
POSTGRES_DB=stockq_dev
POSTGRES_USER=stockq_user
POSTGRES_PASSWORD=stockq_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# Redis token buckets
# capacity limits short bursts; refill rate controls sustained calls per second.
# These are conservative initial values for a small production environment.
OPENAI_BUCKET_ENABLED=True
OPENAI_BUCKET_KEY=rate_limit:openai
OPENAI_BUCKET_CAPACITY=2
OPENAI_BUCKET_REFILL_RATE=1
OPENAI_BUCKET_REDIS_URL=redis://redis:6379/3
FINNHUB_BUCKET_ENABLED=True
FINNHUB_BUCKET_KEY=rate_limit:finnhub
FINNHUB_BUCKET_CAPACITY=2
FINNHUB_BUCKET_REFILL_RATE=1
FINNHUB_BUCKET_REDIS_URL=redis://redis:6379/3
